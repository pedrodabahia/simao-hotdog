# Public — safe to expose in the client bundle (used for read-only access, gated by RLS)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Secret — server-only, NEVER prefix with VITE_ (would get bundled into client JS).
# Find it in Supabase: Settings > API > service_role key.
SUPABASE_SERVICE_ROLE_KEY=
